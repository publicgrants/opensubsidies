{
  "name": "opensubsidies",
  "version": "0.1.0",
  "description": "OpenSubsidies — global, interactive grant intelligence dashboard backed by the grants-sources catalog.",
  "private": true,
  "scripts": {
    "build:data": "tsx scripts/build-catalog.ts && tsx scripts/build-funding-rollups.ts",
    "build:funding": "tsx scripts/build-funding-rollups.ts",
    "db:reset:local": "wrangler d1 execute opensubsidies-db --local --file=scripts/schema.sql && wrangler d1 execute opensubsidies-db --local --file=scripts/.generated/data.sql && wrangler d1 execute opensubsidies-db --local --file=scripts/.generated/funding.sql",
    "db:reset:remote": "wrangler d1 execute opensubsidies-db --remote --file=scripts/schema.sql && wrangler d1 execute opensubsidies-db --remote --file=scripts/.generated/data.sql && wrangler d1 execute opensubsidies-db --remote --file=scripts/.generated/funding.sql",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ajv": ">=6.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "maplibre-gl": "^5.6.0",
    "minimatch": ">=9.0.7",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "shadcn": "^4.7.0",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supercluster": "^7.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wrangler": "^4.97.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
